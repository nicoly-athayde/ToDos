@model AddTaskVM
@{
    ViewData["Title"] = "Adicionar Tarefa";
}
@section Styles {
    <link rel="stylesheet" href="~/css/addTask.css">
}

<div class="form-card">
    <h1 class="form-title"><span> </span> Nova Tarefa</h1>
    <form asp-action="AddTask" method="post">
        @Html.AntiForgeryToken()
        <div class="form-group">
            <label class="form-label" asp-for="Title"></label>
            <input asp-for="Title" class="form-input">
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label class="form-label" asp-for="Description"></label>
            <textarea asp-for="Description" class="formtextarea"></textarea>
            <span asp-validation-for="Description" class="textdanger"></span>
        </div>
        <button type="submit" class="btn-submit"
disabled="@(TempData["Success"] != null)">Criar Tarefa</button>
        <a asp-action="Index" class="btn-cancel"
style="display:block;">Cancelar</a>
    </form>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <partial name="_Notification">
    <script>
        if ('@TempData["Success"]' !== "") {
            howMessage(null, '@TempData["Success"]', 2000, "/");
        }
        if ('@TempData["Failure"]' !== "") {
            showMessage("warning", '@TempData["Failure"]', 5000, null);
        }
    </script>
}