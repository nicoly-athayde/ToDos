@model RegisterVM
@{
    Layout = null;
}

<!DOCTYPE html>

<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initialscale=1.0">
    <title>ToDos Platform - Registro</title>
    <link rel="stylesheet" href="~/css/login.css" />
</head>

<body>
    <div class="login-container">
        <div class="login-card">
            <div class="logo">ToDos Platform</div>
            <h1 class="form-title">Criar nova conta</h1>

            <form id="registerForm" asp-action="Register" method="post">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label class="form-label" asp-for="Name"></label>
                    <input class="form-input" asp-for="Name" />
                    <span class="error-message" asp-validationfor="Name"></span>
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="Email"></label>
                    <input class="form-input" asp-for="Email" />
                    <span class="error-message" asp-validationfor="Email"></span>
                </div>
                <div class="form-group">
                    <label class="form-label" aspfor="Password"></label>
                    <input class="form-input" asp-for="Password" />
                    <span class="error-message" asp-validationfor="Password"></span>
                    <div class="password-strength">
                        <div class="strength-bar" id="strengthBar"></div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label" aspfor="ConfirmPassword"></label>
                        <input class="form-input" asp-for="ConfirmPassword" />
                        <span class="error-message" asp-validationfor="ConfirmPassword"></span>
                    </div>
                    <div class="terms">
                        <div>
                            <input type="checkbox" asp-for="Terms" />
                            <label asp-for="Terms">Eu concordo com os <a href="#">Termos de Serviço</a> e <a href="#">Política de Privacidade</a>
                            </label>
                        </div>
                        <span class="error-message" style="display: block;"
asp-validation-for="Terms"></span>
                        </div>

                        <button type="submit" class="btn-login"
disabled="@(TempData["Success"] != null)">Criar Conta</button>
                        <div class="register-link">
                            Já tem uma conta? <a asp-action="Login">Faça login</a>
                        </div>
                    </form>
                </div>
            </div>
            <script src="~/lib/jquery/dist/jquery.min.js"></script>
            <partial name="_ValidationScriptsPartial" />
            <partial name="_Notification" />
            <script>
                if ('@TempData["Success"]' !== "") {
                    showMessage(null, '@TempData["Success"]', 3000,
'/Account/Login');
                }
                if ('@TempData["Failure"]' !== "") {
                    showMessage("warning", '@TempData["Failure"]', 5000, null);
                }
                $('#registerForm').on('submit', function (e) {
                    // Primeiro verifica se o formulário é válido (validações padrão)
                    if (!$(this).valid()) {
                        e.preventDefault();
                        return false;
                    }
                    // Depois verifica os termos
                    var isChecked = $('#Terms').is(':checked');
                    if (!isChecked) {
                        e.preventDefault();
                        $('#Terms').focus();
                        showMessage('warning', 'Você deve aceitar os termos para continuar', 3000, null);
                        return false;
                    }
                });
            </script>
</body>

</html>
